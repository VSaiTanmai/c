# =============================================================================
# CLIF Storage Infrastructure - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
#   cp .env.example .env
# =============================================================================

# ── ClickHouse ───────────────────────────────────────────────────────────────
CLICKHOUSE_USER=clif_admin
CLICKHOUSE_PASSWORD=clif_secure_password_change_me
CLICKHOUSE_DB=clif_logs
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_INTERSERVER_PORT=9009

# Replica / shard identifiers (node 1)
CLICKHOUSE_SHARD_01=shard_01
CLICKHOUSE_REPLICA_01=replica_01
# Replica / shard identifiers (node 2)
CLICKHOUSE_SHARD_01_R2=shard_01
CLICKHOUSE_REPLICA_02=replica_02

# ── Redpanda ─────────────────────────────────────────────────────────────────
REDPANDA_KAFKA_PORT=9092
REDPANDA_ADMIN_PORT=9644
REDPANDA_SCHEMA_PORT=8081
REDPANDA_PARTITIONS=12
REDPANDA_REPLICATION_FACTOR=3
REDPANDA_LOG_RETENTION_MS=604800000   # 7 days in ms

# ── MinIO (S3-compatible) ────────────────────────────────────────────────────
MINIO_ROOT_USER=clif_minio_admin
MINIO_ROOT_PASSWORD=clif_minio_secret_change_me
MINIO_ENDPOINT=http://minio1:9000
MINIO_CONSOLE_PORT=9003
MINIO_DATA_PORT=9002
MINIO_BUCKET_COLD=clif-cold-logs
MINIO_BUCKET_BACKUPS=clif-backups
MINIO_BUCKET_EVIDENCE=clif-evidence-archive

# ── Consumer Pipeline ────────────────────────────────────────────────────────
CONSUMER_BATCH_SIZE=200000
CONSUMER_FLUSH_INTERVAL_SEC=0.5
CONSUMER_MAX_RETRIES=5
CONSUMER_GROUP_ID=clif-clickhouse-consumer
CONSUMER_POLL_BATCH=10000
CONSUMER_FLUSH_WORKERS=4

# ── Vector ───────────────────────────────────────────────────────────────────
VECTOR_LOG_LEVEL=info
VECTOR_THREADS=4
VECTOR_SYSLOG_PORT=1514
VECTOR_API_PORT=8686
VECTOR_HTTP_PORT=8687
VECTOR_STATSD_PORT=8125
VECTOR_PROM_PORT=9598

# ── Merkle Service ──────────────────────────────────────────────────────────
MERKLE_BATCH_WINDOW=1800
MERKLE_DAEMON_INTERVAL=30

# ── Monitoring ───────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=clif_grafana_change_me

# ── LanceDB ─────────────────────────────────────────────────────────────────
LANCEDB_PORT=8100
LANCEDB_PATH=/data/lancedb
LANCEDB_EMBEDDING_MODEL=all-MiniLM-L6-v2
LANCEDB_SYNC_INTERVAL=30
LANCEDB_SYNC_BATCH=1000

# ── ZooKeeper (ClickHouse Keeper) ────────────────────────────────────────────
ZOOKEEPER_PORT=12181
