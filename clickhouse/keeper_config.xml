<clickhouse>
    <logger>
        <level>warning</level>
        <console>true</console>
    </logger>

    <listen_host>0.0.0.0</listen_host>

    <keeper_server>
        <tcp_port>2181</tcp_port>
        <server_id>1</server_id>
        <log_storage_path>/var/lib/clickhouse-keeper/log</log_storage_path>
        <snapshot_storage_path>/var/lib/clickhouse-keeper/snapshots</snapshot_storage_path>

        <coordination_settings>
            <operation_timeout_ms>10000</operation_timeout_ms>
            <session_timeout_ms>30000</session_timeout_ms>
            <raft_logs_level>warning</raft_logs_level>
            <force_sync>true</force_sync>
            <auto_forwarding>true</auto_forwarding>
            <shutdown_timeout>5000</shutdown_timeout>
            <snapshot_distance>100000</snapshot_distance>
            <snapshots_to_keep>5</snapshots_to_keep>
            <reserved_log_items>200000</reserved_log_items>
            <max_requests_batch_size>100</max_requests_batch_size>
        </coordination_settings>

        <raft_configuration>
            <server>
                <id>1</id>
                <hostname>clickhouse-keeper</hostname>
                <port>9234</port>
            </server>
        </raft_configuration>
    </keeper_server>
</clickhouse>
