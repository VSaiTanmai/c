<clickhouse>
    <profiles>
        <default>
            <!-- Memory: 10 GB per query, unconstrained for production -->
            <max_memory_usage>10000000000</max_memory_usage>
            <max_memory_usage_for_user>20000000000</max_memory_usage_for_user>
            <max_execution_time>300</max_execution_time>
            <load_balancing>random</load_balancing>
            <max_threads>16</max_threads>
            <max_insert_threads>8</max_insert_threads>
            <!-- Async insert — buffer micro-batches server-side -->
            <async_insert>1</async_insert>
            <wait_for_async_insert>0</wait_for_async_insert>
            <async_insert_max_data_size>104857600</async_insert_max_data_size>
            <async_insert_busy_timeout_ms>100</async_insert_busy_timeout_ms>
            <!-- Result safety limits -->
            <max_result_rows>1000000</max_result_rows>
            <max_result_bytes>1073741824</max_result_bytes>
            <result_overflow_mode>break</result_overflow_mode>
            <!-- Distributed query settings -->
            <distributed_product_mode>allow</distributed_product_mode>
            <optimize_read_in_order>1</optimize_read_in_order>
            <compile_expressions>1</compile_expressions>
            <min_count_to_compile_expression>3</min_count_to_compile_expression>
            <!-- Network compression for inter-server communication -->
            <network_compression_method>lz4</network_compression_method>
            <!-- Accept extra fields from Vector direct sinks (clif_event_type,
                 message_body, source_type are routing/AI fields not in CH schema) -->
            <input_format_skip_unknown_fields>1</input_format_skip_unknown_fields>
            <!-- Date/time parsing for ISO 8601 timestamps from Vector -->
            <date_time_input_format>best_effort</date_time_input_format>
        </default>
        <readonly>
            <readonly>1</readonly>
            <max_execution_time>60</max_execution_time>
            <max_memory_usage>5000000000</max_memory_usage>
        </readonly>
        <insert_only>
            <readonly>0</readonly>
            <max_execution_time>120</max_execution_time>
            <max_memory_usage>8000000000</max_memory_usage>
            <max_threads>8</max_threads>
            <max_insert_threads>8</max_insert_threads>
            <async_insert>1</async_insert>
            <wait_for_async_insert>0</wait_for_async_insert>
            <input_format_skip_unknown_fields>1</input_format_skip_unknown_fields>
            <date_time_input_format>best_effort</date_time_input_format>
        </insert_only>
    </profiles>

    <users>
        <!-- clif_admin user is created by Docker entrypoint via
             CLICKHOUSE_USER / CLICKHOUSE_PASSWORD env vars.
             Do NOT define it here to avoid duplicate password fields. -->
    </users>

    <quotas>
        <default>
            <interval>
                <duration>3600</duration>
                <queries>0</queries>
                <errors>0</errors>
                <result_rows>0</result_rows>
                <read_rows>0</read_rows>
                <execution_time>0</execution_time>
            </interval>
        </default>
    </quotas>
</clickhouse>
