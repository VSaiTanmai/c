    networks:
      - clif-backend
    healthcheck:
      test: ["CMD-SHELL", "python -c \"import urllib.request; urllib.request.urlopen('http://localhost:8300/health')\""]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 45s
    logging: *default-logging
    restart: unless-stopped
    deploy:
      resources:
        limits:
          cpus: '1.5'
          memory: 2.5G
        reservations:
          cpus: '0.5'
          memory: 1G

  # ── Triage Agent 4 (v7) ──
  clif-triage-agent-4:
    container_name: clif-triage-agent-4
    hostname: clif-triage-agent-4
    build:
      context: ./agents/triage
      dockerfile: Dockerfile
    <<: *pc1-hosts
    environment:
      KAFKA_BROKERS: "${DATA_IP}:19092,${DATA_IP}:29092,${DATA_IP}:39092"
      CONSUMER_GROUP_ID: "clif-triage-agent"
      INPUT_TOPICS: "raw-logs,security-events,process-events,network-events"
      TOPIC_TRIAGE_SCORES: "triage-scores"
      TOPIC_ANOMALY_ALERTS: "anomaly-alerts"
      TOPIC_HUNTER_TASKS: "hunter-tasks"
      TOPIC_DEAD_LETTER: "dead-letter"
      CLICKHOUSE_HOST: ${DATA_IP}
      CLICKHOUSE_PORT: ${CLICKHOUSE_NATIVE_PORT:-9000}
      CLICKHOUSE_USER: ${CLICKHOUSE_USER:-clif_admin}
      CLICKHOUSE_PASSWORD: ${CLICKHOUSE_PASSWORD:-clif_secure_password_change_me}
      CLICKHOUSE_DB: ${CLICKHOUSE_DB:-clif_logs}
      # ── Drain3
      DRAIN3_DEPTH: 4
      DRAIN3_SIM_TH: 0.4
      DRAIN3_MAX_CHILDREN: 100
