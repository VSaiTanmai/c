      TOPIC_TRIAGE_SCORES: "triage-scores"
      TOPIC_ANOMALY_ALERTS: "anomaly-alerts"
      TOPIC_HUNTER_TASKS: "hunter-tasks"
      TOPIC_DEAD_LETTER: "dead-letter"
      CLICKHOUSE_HOST: ${DATA_IP}
      CLICKHOUSE_PORT: ${CLICKHOUSE_NATIVE_PORT:-9000}
      CLICKHOUSE_USER: ${CLICKHOUSE_USER:-clif_admin}
      CLICKHOUSE_PASSWORD: ${CLICKHOUSE_PASSWORD:-clif_secure_password_change_me}
      CLICKHOUSE_DB: ${CLICKHOUSE_DB:-clif_logs}
      # ── Drain3
      DRAIN3_DEPTH: 4
      DRAIN3_SIM_TH: 0.4
      DRAIN3_MAX_CHILDREN: 100
      DRAIN3_MAX_CLUSTERS: 1024
      DRAIN3_CONFIG_PATH: /app/drain3.ini
      DRAIN3_STATE_PATH: /app/drain3_state.bin
      # ── v7 Models (2-model ensemble: LightGBM + Autoencoder)
      MODEL_DIR: /models
      MODEL_LGBM_PATH: /models/lgbm_v7.onnx
      MODEL_AUTOENCODER_PATH: /models/autoencoder_v7.onnx
      MODEL_AE_CALIBRATION_PATH: /models/ae_calibration_v7.json
      FEATURE_SCALER_PATH: /models/feature_scaler_v7.json
      MANIFEST_PATH: /models/manifest_v7.json
      # ── v7 Score fusion (2-model weights)
      LGBM_WEIGHT: "0.85"
      AUTOENCODER_WEIGHT: "0.15"
      DEFAULT_SUSPICIOUS_THRESHOLD: "0.40"
      DEFAULT_ANOMALOUS_THRESHOLD: "0.90"
      DISAGREEMENT_THRESHOLD: "0.40"
      DISAGREEMENT_ESCALATION_FLOOR: "0.70"
      # ── v7 Operational
      BATCH_SIZE: "2000"
      BATCH_TIMEOUT_MS: "500"
      INFERENCE_WORKERS: "4"
      KAFKA_OFFSET_RESET: "latest"
      # ── EWMA rate tracking (replaces fixed connection windows)
      EWMA_HALF_LIFE_FAST: "2.0"
      EWMA_HALF_LIFE_MEDIUM: "60.0"
      EWMA_HALF_LIFE_SLOW: "600.0"
      EWMA_MAX_ENTITIES: "500000"
      # ── Kill-chain state machine (per-host, 6 stages)
      KILL_CHAIN_DECAY_SEC: "3600.0"
      KILL_CHAIN_SCORE_GATE: "0.30"
      # ── Cross-host correlation
      CROSS_HOST_WINDOW_SEC: "900.0"
      CROSS_HOST_MIN_SCORE: "0.50"
      # ── Connection tracker (sharded)
      CONN_TRACKER_SHARDS: "16"
      CONN_TIME_WINDOW_SEC: "2.0"
      CONN_HOST_WINDOW_SIZE: "100"
      # ── SHAP async explainability
      SHAP_ENABLED: "true"
      SHAP_QUEUE_SIZE: "1000"
      # ── Startup / health
      SELFTEST_ENABLED: "true"
      STARTUP_HEALTH_RETRIES: "30"
      STARTUP_HEALTH_DELAY_SEC: "2.0"
      LOG_LEVEL: INFO
    volumes:
      - ./agents/triage/models:/models:ro
    ports:
      - "8301:8300"
    networks:
      - clif-backend
    healthcheck:
      test: ["CMD-SHELL", "python -c \"import urllib.request; urllib.request.urlopen('http://localhost:8300/health')\""]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 45s
    logging: *default-logging
    restart: unless-stopped
    deploy:
      resources:
        limits:
          cpus: '1.5'
          memory: 2.5G
        reservations:
          cpus: '0.5'
          memory: 1G

  # ── Triage Agent 3 (v7) ──
  clif-triage-agent-3:
    container_name: clif-triage-agent-3
    hostname: clif-triage-agent-3
    build:
      context: ./agents/triage
      dockerfile: Dockerfile
