        limits:
          cpus: '1.5'
          memory: 2.5G
        reservations:
          cpus: '0.5'
          memory: 1G

  # =========================================================================
  # Hunter Agent — Triple-Layer Investigation Pipeline (v7)
  # =========================================================================
  clif-hunter-agent:
    container_name: clif-hunter-agent
    hostname: clif-hunter-agent
    build:
      context: ./agents/hunter
      dockerfile: Dockerfile
    <<: *pc1-hosts
    depends_on:
      lancedb:
        condition: service_healthy
    environment:
      KAFKA_BROKERS: "${DATA_IP}:19092,${DATA_IP}:29092,${DATA_IP}:39092"
      CONSUMER_GROUP_ID: "clif-hunter-agent"
      TOPIC_HUNTER_TASKS: "hunter-tasks"
      TOPIC_HUNTER_RESULTS: "hunter-results"
      TOPIC_DEAD_LETTER: "dead-letter"
      CLICKHOUSE_HOST: ${DATA_IP}
      CLICKHOUSE_PORT: ${CLICKHOUSE_HTTP_PORT:-8123}
      CLICKHOUSE_USER: ${CLICKHOUSE_USER:-clif_admin}
      CLICKHOUSE_PASSWORD: ${CLICKHOUSE_PASSWORD:-Cl1f_Ch@ngeM3_2026!}
      CLICKHOUSE_DB: ${CLICKHOUSE_DB:-clif_logs}
      LANCEDB_URL: "http://lancedb:8100"
      LANCEDB_TIMEOUT_SEC: "3.0"
      LANCEDB_BACKOFF_SEC: "60.0"
      HUNTER_PORT: "8400"
      HUNTER_SCORE_GATE: "0.80"
      INVESTIGATION_WINDOW_MIN: "15"
      HUNTER_CONCURRENCY: "12"
      DEDUP_WINDOW_SEC: "300"
      KAFKA_MAX_POLL_RECORDS: "100"
      SIGMA_RULES_DIR: "/app/sigma/rules"
      CATBOOST_MODEL_PATH: "/app/models/hunter_catboost.cbm"
      MIN_TRAINING_SAMPLES: "100"
      RETRAIN_INTERVAL_SEC: "21600"
      SPC_BASELINE_REFRESH_SEC: "60"
      SPC_WINDOW_HOURS: "24"
      BATCH_SIZE: "100"
      LOG_LEVEL: INFO
    volumes:
      - hunter_models:/app/models
    ports:
      - "8400:8400"
    networks:
      - clif-backend
    healthcheck:
      test: ["CMD-SHELL", "python -c \"import urllib.request; urllib.request.urlopen('http://localhost:8400/health')\""]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s
    logging: *default-logging
    restart: unless-stopped
    deploy:
      resources:
        limits:
          cpus: '1.75'
          memory: 2G
        reservations:
          cpus: '0.5'
          memory: 512M

  # =========================================================================
  # Verifier Agent — Forensic Verification & Explainability AI (XAI)
  # =========================================================================
  clif-verifier-agent:
    container_name: clif-verifier-agent
    hostname: clif-verifier-agent
    build:
      context: ./agents/verifier
      dockerfile: Dockerfile
    <<: *pc1-hosts
    depends_on:
      lancedb:
        condition: service_healthy
    environment:
      KAFKA_BROKERS: "${DATA_IP}:19092,${DATA_IP}:29092,${DATA_IP}:39092"
      CONSUMER_GROUP_ID: "clif-verifier-agent"
      TOPIC_INPUT: "hunter-results"
      TOPIC_OUTPUT: "verifier-results"
      CLIF_HMAC_KEY: ${CLIF_HMAC_KEY:-clif-default-hmac-key-change-me}
      CLICKHOUSE_HOST: ${DATA_IP}
      CLICKHOUSE_PORT: ${CLICKHOUSE_HTTP_PORT:-8123}
      CLICKHOUSE_USER: ${CLICKHOUSE_USER:-clif_admin}
      CLICKHOUSE_PASSWORD: ${CLICKHOUSE_PASSWORD:-Cl1f_Ch@ngeM3_2026!}
      CLICKHOUSE_DATABASE: ${CLICKHOUSE_DB:-clif_logs}
      LANCEDB_URL: "http://lancedb:8100"
      VERIFIER_PORT: "8500"
      SKIP_NEGATIVE_VERDICTS: "true"
      TIMELINE_WINDOW_HOURS: "24"
      FP_SIMILARITY_THRESHOLD: "0.3"
      IOC_LOOKBACK_HOURS: "72"
      EVIDENCE_LOOKBACK_HOURS: "2"
      LOG_LEVEL: INFO
    ports:
      - "8500:8500"
    networks:
      - clif-backend
    healthcheck:
      test: ["CMD-SHELL", "python -c \"import urllib.request; urllib.request.urlopen('http://localhost:8500/health')\""]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s
    logging: *default-logging
    restart: unless-stopped
    deploy:
      resources:
        limits:
          cpus: '1.0'
          memory: 512M
        reservations:
          cpus: '0.25'
          memory: 128M

  # =========================================================================
  # XAI Backend Service — SHAP explainability API for the dashboard (port 8200)
  # =========================================================================
  clif-xai-service:
    container_name: clif-xai-service
    hostname: clif-xai-service
    build:
      context: ./agents/xai-service
      dockerfile: Dockerfile
    environment:
      MODEL_DIR: /models
      MODEL_LGBM_PATH: /models/lgbm_v7.onnx
      FEATURE_SCALER_PATH: /models/feature_scaler_v7.json
      MANIFEST_PATH: /models/manifest_v7.json
      LGBM_TXT_PATH: /models/lgbm_v7.txt
      SHAP_TOP_K: "10"
      XAI_HOST: "0.0.0.0"
      XAI_PORT: "8200"
      LOG_LEVEL: INFO
    ports:
      - "8200:8200"
    volumes:
      - ./agents/triage/models:/models:ro
    networks:
      - clif-backend
      - clif-frontend
    healthcheck:
      test: ["CMD-SHELL", "python -c \"import urllib.request; urllib.request.urlopen('http://localhost:8200/health')\""]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 30s
    logging: *default-logging
    restart: unless-stopped
    deploy:
      resources:
        limits:
          cpus: '0.5'
          memory: 512M
        reservations:
          cpus: '0.1'
          memory: 128M

  # =========================================================================
  # Merkle Evidence Chain Service
  # =========================================================================
  clif-merkle:
    build:
      context: ./merkle-service
      dockerfile: Dockerfile
    container_name: clif-merkle
    hostname: clif-merkle
    <<: *pc1-hosts
    environment:
      CLICKHOUSE_HOST: ${DATA_IP}
      CLICKHOUSE_PORT: 9000
      CLICKHOUSE_USER: ${CLICKHOUSE_USER:-clif_admin}
      CLICKHOUSE_PASSWORD: ${CLICKHOUSE_PASSWORD:-clif_secure_password_change_me}
      CLICKHOUSE_DB: ${CLICKHOUSE_DB:-clif_logs}
      MINIO_ENDPOINT: "http://${DATA_IP}:${MINIO_DATA_PORT:-9002}"
      MINIO_ROOT_USER: ${MINIO_ROOT_USER:-clif_minio_admin}
      MINIO_ROOT_PASSWORD: ${MINIO_ROOT_PASSWORD:-clif_minio_secret_change_me}
      MINIO_BUCKET_EVIDENCE: ${MINIO_BUCKET_EVIDENCE:-clif-evidence-archive}
      MERKLE_BATCH_WINDOW: ${MERKLE_BATCH_WINDOW:-1800}
      MERKLE_DAEMON_INTERVAL: ${MERKLE_DAEMON_INTERVAL:-30}
      LOG_LEVEL: INFO
    networks:
      - clif-backend
    healthcheck:
      test: ["CMD-SHELL", "python -c 'import socket; s=socket.socket(); s.settimeout(2); s.connect((\"clickhouse01\",9000)); s.close()' || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 30s
    logging: *default-logging
    restart: unless-stopped
    deploy:
      resources:
        limits:
          cpus: '0.5'
          memory: 256M
        reservations:
          cpus: '0.1'
          memory: 128M

  # =========================================================================
  # LanceDB — Semantic Vector Search & RAG Engine
  # =========================================================================
  lancedb:
    container_name: clif-lancedb
    build:
      context: ./lancedb-service
      dockerfile: Dockerfile
    <<: *pc1-hosts
    environment:
      LANCEDB_PATH: /data/lancedb
      EMBEDDING_MODEL: all-MiniLM-L6-v2
      EMBEDDING_BATCH_SIZE: 256
      EMBEDDING_DIM: 384
      CLICKHOUSE_HOST: ${DATA_IP}
      CLICKHOUSE_PORT: ${CLICKHOUSE_NATIVE_PORT:-9000}
      CLICKHOUSE_USER: ${CLICKHOUSE_USER:-clif_admin}
      CLICKHOUSE_PASSWORD: ${CLICKHOUSE_PASSWORD:-clif_secure_password_change_me}
      CLICKHOUSE_DB: ${CLICKHOUSE_DB:-clif_logs}
      SYNC_INTERVAL_SEC: 30
      SYNC_BATCH_SIZE: 1000
      API_HOST: 0.0.0.0
      API_PORT: 8100
      LOG_LEVEL: INFO
      CORS_ORIGINS: "http://localhost:3001,http://clif-dashboard:3001"
    ports:
      - "8100:8100"
    volumes:
      - lancedb_data:/data/lancedb
    networks:
      - clif-backend
      - clif-frontend
    healthcheck:
      test: ["CMD-SHELL", "curl -sf http://localhost:8100/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s
    logging: *default-logging
    restart: unless-stopped
    deploy:
      resources:
        limits:
          cpus: '1'
          memory: 2G
        reservations:
          cpus: '0.5'
          memory: 768M

  # =========================================================================
  # Redpanda Console (web UI — connects to PC1 brokers)
  # =========================================================================
  redpanda-console:
    image: redpandadata/console:v2.7.2
    container_name: clif-redpanda-console
    hostname: redpanda-console
    extra_hosts:
      - "pc1-rp01:${DATA_IP}"
      - "pc1-rp02:${DATA_IP}"
      - "pc1-rp03:${DATA_IP}"
    ports:
      - "8080:8080"
    environment:
      CONFIG_FILEPATH: /tmp/config.yml
    volumes:
      - ./cluster/redpanda/console-config.yml:/tmp/config.yml:ro
    networks:
      - clif-frontend
      - clif-backend
    healthcheck:
      test: ["CMD-SHELL", "curl -sf http://localhost:8080/admin/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 20s
    logging: *default-logging
    restart: unless-stopped
    deploy:
      resources:
        limits:
          cpus: '0.25'
          memory: 256M

  # =========================================================================
  # Prometheus (scrapes both PC1 data tier & local compute tier)
  # =========================================================================
  prometheus:
    image: prom/prometheus:v2.54.0
    container_name: clif-prometheus
    hostname: prometheus
    extra_hosts:
      - "clickhouse01:${DATA_IP}"
      - "clickhouse02:${DATA_IP}"
      - "clickhouse-keeper:${DATA_IP}"
      - "minio1:${DATA_IP}"
      - "redpanda01:${DATA_IP}"
      - "redpanda02:${DATA_IP}"
      - "redpanda03:${DATA_IP}"
    ports:
      - "${PROMETHEUS_PORT:-9090}:9090"
    volumes:
      - ./cluster/monitoring/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - ./monitoring/alert_rules.yml:/etc/prometheus/alert_rules.yml:ro
      - prometheus_data:/prometheus
    command:
      - "--config.file=/etc/prometheus/prometheus.yml"
      - "--storage.tsdb.retention.time=7d"
      - "--web.enable-lifecycle"
    networks:
      - clif-frontend
      - clif-backend
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://localhost:9090/-/healthy || exit 1"]
      interval: 15s
      timeout: 5s
      retries: 5
      start_period: 10s
    logging: *default-logging
    restart: unless-stopped
    deploy:
      resources:
        limits:
          cpus: '0.5'
          memory: 512M
        reservations:
          cpus: '0.1'
          memory: 256M

  # =========================================================================
  # Grafana
  # =========================================================================
  grafana:
    image: grafana/grafana:11.1.4
    container_name: clif-grafana
    hostname: grafana
    extra_hosts:
      - "clickhouse01:${DATA_IP}"
    ports:
      - "${GRAFANA_PORT:-3002}:3000"
    environment:
      GF_SECURITY_ADMIN_USER: ${GRAFANA_ADMIN_USER:-admin}
      GF_SECURITY_ADMIN_PASSWORD: ${GRAFANA_ADMIN_PASSWORD:-clif_grafana_change_me}
      GF_DASHBOARDS_DEFAULT_HOME_DASHBOARD_PATH: /var/lib/grafana/dashboards/clif-overview.json
    volumes:
      - grafana_data:/var/lib/grafana
      - ./monitoring/grafana-dashboard.json:/var/lib/grafana/dashboards/clif-overview.json:ro
      - ./cluster/monitoring/grafana-datasources.yml:/etc/grafana/provisioning/datasources/datasources.yml:ro
      - ./monitoring/grafana-dashboards.yml:/etc/grafana/provisioning/dashboards/dashboards.yml:ro
    networks:
      - clif-frontend
    depends_on:
      - prometheus
    healthcheck:
      test: ["CMD-SHELL", "curl -sf http://localhost:3000/api/health || exit 1"]
      interval: 15s
      timeout: 5s
      retries: 5
      start_period: 15s
    logging: *default-logging
    restart: unless-stopped
    deploy:
      resources:
        limits:
          cpus: '0.25'
          memory: 256M
        reservations:
          cpus: '0.1'
          memory: 128M
